{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "rootDir": ".",
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "include": ["server/**/*.ts", "client/src/**/*.ts", "client/src/**/*.tsx"]
}
